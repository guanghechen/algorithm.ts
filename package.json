{
  "name": "@algorithm.ts/root",
  "version": "0.0.0",
  "private": true,
  "author": {
    "name": "guanghechen",
    "url": "https://github.com/guanghechen/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/guanghechen/algorithm.ts"
  },
  "homepage": "https://github.com/guanghechen/algorithm.ts",
  "type": "module",
  "scripts": {
    ":publish": "pnpm clean && pnpm build:production && pnpm test:coverage && pnpm -r publish --no-git-checks",
    ":publish:all": "pnpm -r exec npm version patch --no-git-tag-version && pnpm -r publish --no-git-checks",
    ":upgrade": "pnpm update -i && pnpm clean && pnpm format && pnpm build && pnpm test",
    "build": "cross-env NODE_ENV=production ROLLUP_SHOULD_SOURCEMAP=true pnpm -r run build",
    "build:production": "cross-env NODE_ENV=production ROLLUP_SHOULD_SOURCEMAP=false pnpm -r run build",
    "clean": "pnpm -r run clean && pnpm install",
    "format": "pnpm format:lintfix && pnpm format:prettier",
    "format:prettier": "prettier . --write",
    "format:lintfix": "eslint . --fix",
    "prepublishOnly": "pinst --disable",
    "postinstall": "is-ci || husky",
    "postpublish": "pinst --enable",
    "rebuild": "pnpm clean && pnpm build",
    "run:ts": "node --loader ts-node/esm",
    "test": "pnpm -r run --if-present test",
    "test:coverage": "pnpm -r run --if-present test:coverage",
    "test:update": "pnpm -r run --if-present test:update",
    "version": "pnpm install && ghc-doc-link-rewrite && git stage -u pnpm-lock.yaml packages/**/package.json packages/**/*.md"
  },
  "devDependencies": {
    "@guanghechen/chalk": "^1.0.4",
    "@guanghechen/eslint-config": "^7.0.19",
    "@guanghechen/monorepo": "^1.0.4",
    "@guanghechen/reporter": "^1.0.6",
    "@guanghechen/rollup-config": "^6.0.10",
    "@guanghechen/script-doc-link": "^6.0.7",
    "@types/node": "20.19.8",
    "@vitest/coverage-v8": "4.0.18",
    "cross-env": "7.0.3",
    "eslint": "9.31.0",
    "husky": "9.1.7",
    "is-ci": "4.1.0",
    "lint-staged": "16.1.2",
    "pinst": "3.0.0",
    "prettier": "3.6.2",
    "rimraf": "6.0.1",
    "rollup": "4.45.1",
    "ts-node": "10.9.2",
    "tslib": "2.8.1",
    "typescript": "5.8.3",
    "vitest": "4.0.18"
  },
  "lint-staged": {
    "*.{js,ts,mts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{md,json,eslintrc}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.7.1"
}
